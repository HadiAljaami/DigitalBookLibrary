src/DigitalBookLibrary.WebAPI/App_Data/uploads/**
!src/DigitalBookLibrary.WebAPI/App_Data/uploads/.gitkeep
src/DigitalBookLibrary.WebAPI/wwwroot/uploads/*
!src/DigitalBookLibrary.WebAPI/wwwroot/uploads/.gitkeep

